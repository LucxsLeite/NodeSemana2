// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid()) @map("public_id")
  nome      String
  email     String  @unique
  senhaHash String  @map("senha_hash")
  foto      String?

  token          String?   @unique
  tokenExpiresAt DateTime? @map("token_expires_at")

  posts   Post[]
  coments Coment[]
  likes   Like[]

  @@map("users")
}

model Post {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id")
  titulo    String
  conteudo  String
  createdAt DateTime @default(now()) @map("created_at")

  usuarioId Int     @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  coments Coment[]
  likes   Like[]

  @@map("posts")
}

model Coment {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id")
  conteudo  String
  createdAt DateTime @default(now()) @map("created_at")

  usuarioId Int     @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  likes Like[]

  @@map("coments")
}

model Like {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id")
  createdAt DateTime @default(now()) @map("created_at")

  usuarioId Int     @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  postId Int?
  post   Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  comentId Int?
  coment   Coment? @relation(fields: [comentId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, postId])
  @@unique([usuarioId, comentId])
  @@map("likes")
}
